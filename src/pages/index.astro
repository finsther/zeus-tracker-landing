---
export const prerender = false;

import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/sections/Hero.astro';
import Trending from '@/components/sections/Trending.astro';
import BestMovies from '@/components/sections/BestMovies.astro';
import MustWatchSeries from '@/components/sections/MustWatchSeries.astro';
import GenreExplorer from '@/components/sections/GenreExplorer.astro';
import RecentReviews from '@/components/sections/RecentReviews.astro';
import FAQ from '@/components/sections/FAQ.astro';
import CategoryExplorer from '@/components/sections/CategoryExplorer.astro';
import {
  trendingSeries as trending,
  bestMovies,
  mustWatchSeries,
  genres,
  recentReviews,
  faqItems as faq,
  categories,
} from '@/mocks';
---

<BaseLayout
  title="Clak TV — Películas y series que debes ver"
  description="Descubre las películas y series más populares. Lleva tu historial, escribe reseñas y encuentra tu próximo favorito. El diario personal de todo lo que ves."
>
  <Hero />
  <Trending series={trending} />
  <BestMovies movies={bestMovies} />
  <MustWatchSeries series={mustWatchSeries} />
  <GenreExplorer genres={genres} />
  <RecentReviews reviews={recentReviews} />
  <FAQ items={faq} />
  <CategoryExplorer categories={categories} />
  {/* TODO: Info CTA */}
</BaseLayout>
