---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/sections/Hero.astro';
import Trending from '@/components/sections/Trending.astro';
import BestMovies from '@/components/sections/BestMovies.astro';
import MustWatchSeries from '@/components/sections/MustWatchSeries.astro';
import GenreExplorer from '@/components/sections/GenreExplorer.astro';
import RecentReviews from '@/components/sections/RecentReviews.astro';
import FAQ from '@/components/sections/FAQ.astro';
import CategoryExplorer from '@/components/sections/CategoryExplorer.astro';
import InfoCTA from '@/components/sections/InfoCTA.astro';

import { fetchFromAPI } from '@/lib/api';
import type {
  Series,
  Movie,
  Genre,
  Review,
  FAQItem,
  Category,
} from '@/types';

export const prerender = false;

interface HomeData {
  trending: Series[];
  bestMovies: Movie[];
  mustWatchSeries: Series[];
  genres: Genre[];
  recentReviews: Review[];
  faq: FAQItem[];
  categories: Category[];
}

let trending: Series[];
let bestMovies: Movie[];
let mustWatchSeries: Series[];
let genres: Genre[];
let recentReviews: Review[];
let faq: FAQItem[];
let categories: Category[];

try {
  const data = await fetchFromAPI<HomeData>('/api/v1/public/home');

  ({
    trending,
    bestMovies,
    mustWatchSeries,
    genres,
    recentReviews,
    faq,
    categories,
  } = data);
} catch (error) {
  console.error('[index] BFF fetch failed, using mocks:', error);

  const mocks = await import('@/mocks');

  trending = mocks.trendingSeries;
  bestMovies = mocks.bestMovies;
  mustWatchSeries = mocks.mustWatchSeries;
  genres = mocks.genres;
  recentReviews = mocks.recentReviews;
  faq = mocks.faqItems;
  categories = mocks.categories;
}
---

<BaseLayout
  title="Clak TV — Películas y series que debes ver"
  description="Descubre las películas y series más populares. Lleva tu historial, escribe reseñas y encuentra tu próximo favorito. El diario personal de todo lo que ves."
>
  <Hero />
  <Trending series={trending} />
  <BestMovies movies={bestMovies} />
  <MustWatchSeries series={mustWatchSeries} />
  <GenreExplorer genres={genres} />
  <RecentReviews reviews={recentReviews} />
  <FAQ items={faq} />
  <CategoryExplorer categories={categories} />
  <InfoCTA />
</BaseLayout>
