---
import { Icon } from 'astro-icon/components';
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'a'> {
  variant?: 'primary' | 'secondary';
  icon?: string;
}

const { variant = 'primary', icon, class: className, ...rest } = Astro.props;

const base =
  'inline-flex items-center gap-2 px-5 py-3 rounded-[10px] text-3 font-semibold font-body transition-transform active:scale-[0.97] no-underline [&_svg]:size-3.5';

const variants = {
  primary: 'bg-accent text-accent-contrast',
  secondary: 'bg-background-elev1 text-fg border border-border-strong',
};
---

<a class:list={[base, variants[variant], className]} {...rest}>
  <slot />
  {icon && <Icon name={icon} aria-hidden="true" />}
</a>
