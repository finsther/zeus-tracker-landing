---
import type { Genre } from '@/types';

interface Props {
  genre: Genre;
}

const { genre } = Astro.props;
---

<a
  href={`/genre/${genre.slug}`}
  class="relative aspect-3/2 rounded-[14px] overflow-hidden border border-border cursor-pointer transition-transform duration-200 hover:-translate-y-0.75"
>
  <img
    src={genre.coverImage}
    alt=""
    loading="lazy"
    class="absolute inset-0 size-full object-cover"
  />

  <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(11,13,18,0.1)_0%,rgba(11,13,18,0.85)_100%)]"></div>

  <div class="absolute inset-0 z-2 p-5 flex flex-col justify-end">
    <h3 class="font-display font-semibold text-[22px] tracking-tight m-0 mb-1 text-white">
      {genre.name}
    </h3>

    <span class="font-mono text-1 text-white/70">
      {genre.totalSeries} series · {genre.totalMovies} pelis
    </span>
  </div>
</a>
