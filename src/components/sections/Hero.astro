---
import Button from '@/components/ui/Button.astro';
---

<section class="hero relative overflow-hidden text-center pt-25 pb-[80px] px-6">
  <div class="relative z-2 max-w-225 mx-auto">
    <span class="inline-flex items-center gap-1.5 px-3 py-1.25 rounded-full bg-accent-soft text-accent text-2 font-semibold tracking-[0.04em] mb-6">
      <span class="size-1.5 rounded-full bg-accent [box-shadow:0_0_8px_var(--color-accent)]"></span>
      Actualizado abril 2026
    </span>

    <h1 class="font-display font-semibold text-[clamp(40px,6vw,72px)] leading-none tracking-[-0.035em] mt-0 mb-5">
      Lo que <em class="italic text-accent font-medium">todos están viendo</em> en 2026.
    </h1>

    <p class="text-[17px] text-fg-muted mt-0 mb-8 leading-body">
      Ranking en tiempo real basado en vistas reales, no en lo que los estudios quieren que veas.
    </p>

    <div class="inline-flex gap-2.5">
      <Button href="#" variant="primary" icon="ri:arrow-right-line">Crear cuenta</Button>
      <Button href="#" variant="secondary" icon="ri:login-box-line">Iniciar sesión</Button>
    </div>
  </div>
</section>

<style>
  .hero {
    background:
      radial-gradient(ellipse 70% 50% at 50% 40%, rgba(255, 210, 63, 0.10) 0%, transparent 60%),
      var(--color-background);
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: repeating-linear-gradient(0deg, rgba(255, 255, 255, 0.02) 0 1px, transparent 1px 3px);
    opacity: 0.4;
    mix-blend-mode: overlay;
  }
</style>
