---
import type { FAQItem } from '@/types';

interface Props {
  items: FAQItem[];
}

const { items } = Astro.props;
---

<section
  id="faq"
  class="px-10 py-[64px] bg-background-elev1 border-t border-border max-[900px]:px-5 max-[900px]:py-[48px]"
>
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-[1fr_1.2fr] gap-[48px] items-start max-[900px]:grid-cols-1 max-[900px]:gap-6">
      <div>
        <h2 class="font-display font-semibold text-[40px] tracking-[-0.03em] leading-none m-0 mb-3">
          Preguntas <em class="italic text-accent font-medium">frecuentes</em>.
        </h2>

        <p class="text-fg-muted text-[15px] leading-[1.55] m-0">
          Lo que más nos preguntan sobre cómo funciona Clak, los datos y la privacidad.
        </p>
      </div>

      <div class="flex flex-col gap-1.5">
        {items.map((item, i) => (
          <details
            class="faq bg-background-elev1 border border-border rounded-[10px] overflow-hidden open:border-border-strong"
            open={i === 0}
          >
            <summary class="cursor-pointer px-5 py-4 flex justify-between gap-3 text-[15px] font-semibold text-fg">
              {item.question}
            </summary>

            <div class="px-5 pb-4.5 text-fg-muted text-3 leading-[1.55]">
              {item.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .faq summary {
    list-style: none;
  }

  .faq summary::-webkit-details-marker {
    display: none;
  }

  .faq summary::after {
    content: '+';
    font-family: var(--font-mono);
    font-size: 20px;
    color: var(--color-fg-muted);
    line-height: 1;
  }

  .faq[open] summary::after {
    content: '−';
  }
</style>
